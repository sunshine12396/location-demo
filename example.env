# ──────────────────────────────────────────────
# PostgreSQL Configuration
# ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=location_demo

# ──────────────────────────────────────────────
# Backend Configuration
# ──────────────────────────────────────────────
SERVER_PORT=8088
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=location_demo
DB_SSLMODE=disable
EXTERNAL_API_KEY=your_google_api_key
LOCATION_SYNC_DAYS=30

# ──────────────────────────────────────────────
# Frontend Configuration
# ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://backend:8088/api/v1
INTERNAL_API_URL=http://backend:8088/api/v1
